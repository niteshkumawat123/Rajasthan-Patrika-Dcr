@model HODashboardViewModel
<div class="topbar">
    <div class="topbar-logo">&#x1F4F0; <span>DCR</span></div>
    <div class="topbar-user">
        <b>@Model.User?.EmpName</b>
        <span class="role-badge role-ho">Jaipur HO</span>
    </div>
</div>
<div class="scroll-area">
    <div class="ho-date-row fade-in">
        <label>&#x1F4C5; Date</label>
        <input type="date" id="ho-date-filter" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" onchange="window.location.href='/HO/Dashboard?selectedDate='+this.value">
    </div>
    <div class="copy-counts-row fade-in">
        <div class="copy-count-box increase-box">
            <div class="copy-count-num increase">@Model.TotalIncreased</div>
            <div class="copy-count-label">&#x1F4C8; Total Increased Copies</div>
        </div>
        <div class="copy-count-box decrease-box">
            <div class="copy-count-num decrease">@Model.TotalDecreased</div>
            <div class="copy-count-label">&#x1F4C9; Total Decreased Copies</div>
        </div>
    </div>
    <div class="stats-row fade-in-2">
        <div class="stat-card purple"><div class="stat-num purple">@Model.AwaitingHo</div><div class="stat-label">Awaiting HO</div></div>
        <div class="stat-card green"><div class="stat-num green">@Model.HoApproved</div><div class="stat-label">HO Approved</div></div>
    </div>
    <div class="fade-in-3">
        <div class="section-header">
            <div class="section-title">Pending HO Approval</div>
            <span class="status-pill ho_review">@Model.PendingRequests.Count</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var req in Model.PendingRequests)
            {
                <div class="request-card">
                    <div class="request-row">
                        <span style="font-weight:700;">@req.Agcd - @req.AgName</span>
                        <span class="status-pill pending-ho">PENDING_HO</span>
                    </div>
                    <div class="request-row" style="font-size:12px;color:var(--muted);">
                        <span>@req.Publ / @req.Edtn | Zone: @req.ZoneCode</span>
                    </div>
                    <div class="request-row" style="font-size:13px;">
                        <span>@req.BaseSupply &#x2192; @req.ChangedSupply
                            @if(req.IncDec=="I"){<span style="color:var(--green);">&#x2191;</span>}else{<span style="color:var(--accent);">&#x2193;</span>}
                        </span>
                    </div>
                    @if(req.ZhApprovedBy!=null){
                        <div class="request-row" style="font-size:11px;color:var(--muted);">
                            <span>ZH: @req.ZhApprovedBy</span><span>@req.ZhRemarks</span>
                        </div>
                    }
                    <div class="action-row" style="margin-top:8px;">
                        <button class="btn btn-sm" style="background:var(--green);color:#fff;"
                                onclick="hoApprove(@req.ReqId,'@req.Agcd','@req.Dpcd','@req.Publ','@req.Edtn','@req.SupplyTypeCode',@(req.ChangedSupply??0),'@req.ChangedSupplyDate?.ToString("yyyy-MM-dd")')">&#x2705; Approve &amp; Push ERP</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<div class="bottom-nav">
    <a class="nav-btn active" href="@Url.Action("Dashboard","HO")"><span class="nav-icon">&#x1F3E0;</span>Home</a>
    <a class="nav-btn" href="@Url.Action("History","HO")"><span class="nav-icon">&#x1F4CB;</span>History</a>
    <a class="nav-btn" href="@Url.Action("Reports","HO")"><span class="nav-icon">&#x1F4CA;</span>Reports</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon">&#x1F464;</span>Profile</a>
</div>
@section Scripts {
<script>
let hoReqData={};
function hoApprove(reqId,agcd,dpcd,publ,edtn,stc,cs,csd){
    hoReqData={reqId,agcd,dpcd,publ,edtn,supplyTypeCode:stc,changedSupply:cs,changedSupplyDate:csd};
    document.getElementById('remarks-modal-title').textContent='Approve & Push to ERP';
    openModal('remarks-modal');
}
function confirmRemarksAction(){
    let remarks=document.getElementById('remarks-modal-input').value;
    let body='reqId='+hoReqData.reqId+'&remarks='+encodeURIComponent(remarks)
        +'&agcd='+hoReqData.agcd+'&dpcd='+hoReqData.dpcd
        +'&publ='+hoReqData.publ+'&edtn='+hoReqData.edtn
        +'&supplyTypeCode='+hoReqData.supplyTypeCode
        +'&changedSupply='+hoReqData.changedSupply
        +'&changedSupplyDate='+hoReqData.changedSupplyDate;
    fetch('/HO/Approve',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body})
        .then(r=>r.json()).then(d=>{
            closeModal('remarks-modal');
            showToast(d.message,d.success?'success':'error');
            if(d.success) setTimeout(()=>location.reload(),1000);
        });
}
</script>
}
