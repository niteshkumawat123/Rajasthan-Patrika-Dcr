@model ReportPageViewModel
<div class="topbar">
    <a href="@Url.Action("Dashboard","HO")" class="btn btn-secondary btn-sm" style="width:auto;padding:4px 8px;text-decoration:none;">? Back</a>
    <div style="font-size:15px;font-weight:800;">Reports</div>
    <div style="width:60px;"></div>
</div>
<div class="scroll-area">
    <div class="ho-date-row fade-in" style="margin-bottom:14px;">
        <label>?? Date</label>
        <input type="date" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" onchange="window.location.href='/HO/Reports?selectedDate='+this.value">
    </div>
    <div class="card fade-in">
        <div class="card-title">Branch-wise Summary</div>
        @foreach (var b in Model.BranchSummary)
        {
            <div class="report-branch-row">
                <div class="request-row"><span style="font-weight:700;">@b.ZoneCode / @b.BranchCode</span><span>@b.TotalRequests requests</span></div>
                <div class="request-row" style="font-size:12px;color:var(--muted);">
                    <span style="color:var(--green);">? @b.Increases (+@b.NetIncCopies)</span>
                    <span style="color:var(--accent);">? @b.Decreases (-@b.NetDecCopies)</span>
                    <span>ERP: @b.PushedToErp</span>
                </div>
            </div>
        }
        @if (!Model.BranchSummary.Any())
        {
            <div style="text-align:center;color:var(--muted);padding:20px;">No data for selected date.</div>
        }
    </div>
    <div class="card fade-in-3">
        <div class="card-title">ERP Push Log</div>
        @foreach (var e in Model.ErpPushLog)
        {
            <div class="request-card" style="margin-bottom:8px;">
                <div class="request-row"><span style="font-weight:700;">#@e.ReqId @e.Agcd</span><span>@e.AgName</span></div>
                <div class="request-row" style="font-size:12px;">
                    <span>@e.Publ/@e.Edtn</span>
                    <span>@e.BaseSupply ? @e.ChangedSupply @(e.IncDec=="I"?"?":"?")</span>
                </div>
                <div class="request-row" style="font-size:11px;color:var(--muted);">
                    <span>Pushed by @e.PushedBy</span><span>@e.ErpPushDate?.ToString("dd MMM HH:mm")</span>
                </div>
            </div>
        }
        @if (!Model.ErpPushLog.Any())
        {
            <div style="text-align:center;color:var(--muted);padding:20px;">No ERP pushes for selected date.</div>
        }
    </div>
</div>
<div class="bottom-nav">
    <a class="nav-btn" href="@Url.Action("Dashboard","HO")"><span class="nav-icon">??</span>Home</a>
    <a class="nav-btn" href="@Url.Action("History","HO")"><span class="nav-icon">??</span>History</a>
    <a class="nav-btn active" href="@Url.Action("Reports","HO")"><span class="nav-icon">??</span>Reports</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon">??</span>Profile</a>
</div>
