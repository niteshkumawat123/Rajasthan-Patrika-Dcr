        cmd.Parameters.Add(new OracleParameter("COMP_CODE", compCode));
        using var reader = await cmd.ExecuteReaderAsync();
        while (await reader.ReadAsync())
        {
            list.Add(MapSupplyRequestWithApproval(reader));
