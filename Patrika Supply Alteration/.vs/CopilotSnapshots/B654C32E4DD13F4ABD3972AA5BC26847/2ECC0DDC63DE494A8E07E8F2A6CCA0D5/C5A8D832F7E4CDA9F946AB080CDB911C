        if (await reader.ReadAsync())
        {
            return (
                Convert.ToInt32(reader["PENDING"]),
                Convert.ToInt32(reader["APPROVED"]),
                Convert.ToInt32(reader["REJECTED"]),
                Convert.ToInt32(reader["TODAY"])
            );
