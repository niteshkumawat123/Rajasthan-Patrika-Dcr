<!DOCTYPE html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#0a0f1e">
    <title>Patrika Supply Alteration</title>
    <link rel="icon" type="image/jpeg" href="/icons/PatrikaFaveIcon.jpeg">
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    <style>
        @@keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @@keyframes slideOutRight {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }
    </style>
</head>
<body>
    <button id="theme-fab" title="Toggle theme">&#x1F319;</button>
    <div id="app">
        <div class="screen active">
            @RenderBody()
        </div>
    </div>
    <div id="toast"></div>
    <partial name="_Modal" />
    <script src="~/js/app.js"></script>
    <!-- Firebase Notifications -->
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-messaging-compat.js"></script>
    <script src="~/js/firebase-init.js"></script>
    @{
        var userJson = Context.Session.GetString("DCR_User");
        DCRSupplyApp.Models.UserSessionModel? sessionUser = null;
        if (!string.IsNullOrEmpty(userJson))
        {
            sessionUser = System.Text.Json.JsonSerializer.Deserialize<DCRSupplyApp.Models.UserSessionModel>(userJson);
        }
    }
    @if (sessionUser != null)
    {
        var roleTopic = sessionUser.RoleDetails?.FirstOrDefault()?.RoleId == "7" ? "HO"
                      : sessionUser.RoleDetails?.FirstOrDefault()?.RoleId == "4" ? "ZH"
                      : "Executive";
        <script>
            initFirebaseNotifications('@sessionUser.EmpCode', '@roleTopic');
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
