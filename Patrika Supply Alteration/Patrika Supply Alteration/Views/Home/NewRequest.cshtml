@{
    ViewData["Title"] = "New Request";
    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
}
<div class="topbar">
    <a href="@Url.Action("Dashboard", ctrl)" class="btn btn-secondary btn-sm" style="width:auto;padding:4px 8px;text-decoration:none;">&#x2190; Back</a>
    <div style="font-size:15px;font-weight:800;">New Request</div>
    <div style="width:60px;"></div>
</div>
<div class="scroll-area">
    <div class="card fade-in">
        <div class="card-title">Request Type</div>
        <div class="chip-row">
            <div class="chip increase active" id="chip-increase" onclick="selectType('increase')">&#x1F4C8; Increase</div>
            <div class="chip decrease" id="chip-decrease" onclick="selectType('decrease')">&#x1F4C9; Decrease</div>
        </div>
    </div>
    <div class="card fade-in-2">
        <div class="card-title">Agency Details (from ERP)</div>
        <div class="field" style="position:relative;">
            <label>Search Agency (Name or Code) *</label>
            <input type="text" id="agent-search" placeholder="Type agency name or code..." autocomplete="off" oninput="searchAgent(this.value)">
            <div id="agent-dropdown" style="display:none;position:absolute;top:100%;left:0;right:0;z-index:200;background:var(--surface);border:1.5px solid var(--border);border-radius:10px;max-height:220px;overflow-y:auto;margin-top:4px;box-shadow:0 8px 24px rgba(0,0,0,0.3);"></div>
            <div class="erp-loading" id="erp-loading" style="display:none;">&#x231B; Searching...</div>
            <div class="erp-ok" id="erp-ok" style="display:none;">&#x2705; Agency found in ERP</div>
        </div>
        <div class="field">
            <label>Agency Name (auto-filled)</label>
            <input type="text" id="agent-name" placeholder="Auto-filled on selection" readonly style="opacity:0.7;">
        </div>
        <div class="input-row">
            <div class="field">
                <label>Agency Code</label>
                <input type="text" id="agent-code" placeholder="Auto-filled" readonly style="opacity:0.7;">
            </div>
            <div class="field">
                <label>Branch</label>
                <input type="text" id="agent-zone-disp" placeholder="Auto-filled" readonly style="opacity:0.7;">
            </div>
        </div>
        <div class="input-row">
            <div class="field">
                <label>Effective Date *</label>
                <input type="date" id="eff-date" value="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" readonly style="opacity:0.7;">
            </div>
            <div class="field">
                <label>Drop Point</label>
                <input type="text" id="agent-droppoint" placeholder="Auto-filled" readonly style="opacity:0.7;">
            </div>
        </div>
        <div class="input-row">
            <div class="field">
                <label>Publication</label>
                <input type="text" id="agent-publ-name" placeholder="Auto-filled" readonly style="opacity:0.7;">
            </div>
            <div class="field">
                <label>Edition</label>
                <input type="text" id="agent-edtn-name" placeholder="Auto-filled" readonly style="opacity:0.7;">
            </div>
        </div>
    </div>
   @*  <div class="card fade-in-3" id="supply-card" style="display:none;">
        <div class="card-title">Current Supply</div>
        <div id="supply-table"></div>
    </div> *@
    <div class="card fade-in-3">
        <div class="card-title">Supply Details</div>
        <div class="input-row">
            <div class="field">
                <label>Current Supply (ERP)</label>
                <input type="number" id="old-supply" placeholder="Auto-filled" min="0" readonly style="opacity:0.8;background:rgba(78,140,255,0.06);border-color:rgba(78,140,255,0.2);">
            </div>
            <div class="field">
                <label id="qty-label">Increased Quantity *</label>
                <input type="number" id="new-supply" placeholder="Enter qty" min="1" oninput="calcDiff()">
            </div>
        </div>
        <div class="supply-diff">
            <div style="text-align:center"><div class="supply-num" id="prev-old">—</div><div class="supply-sub">Current</div></div>
            <div class="arrow">&#x2192;</div>
            <div style="text-align:center"><div class="supply-num" id="prev-new">—</div><div class="supply-sub">Quantity</div></div>
            <div style="text-align:center"><div class="supply-num" id="prev-diff" style="font-size:18px;">—</div><div class="supply-sub">Total</div></div>
        </div>
        <div id="supply-error" style="display:none;font-size:12px;color:var(--accent);margin-top:8px;"></div>
        <div style="margin-top:14px;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;font-weight:600;color:var(--paper);">
                <input type="checkbox" id="daywise-toggle" onchange="toggleDayWise()" style="width:18px;height:18px;accent-color:var(--blue);">
                Edit Day-wise Supply
            </label>
        </div>
        <div id="daywise-section" style="display:none;margin-top:12px;background:rgba(78,140,255,0.04);border:1px solid var(--border);border-radius:10px;padding:14px;">
            <div style="font-size:12px;color:var(--muted);margin-bottom:10px;">&#x1F4C5; Customize supply for each day (independent of increase/decrease quantity above)</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
                <div class="field" style="margin:0;"><label style="font-size:11px;">Monday</label><input type="number" id="dw-mon" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Tuesday</label><input type="number" id="dw-tue" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Wednesday</label><input type="number" id="dw-wed" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Thursday</label><input type="number" id="dw-thu" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Friday</label><input type="number" id="dw-fri" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Saturday</label><input type="number" id="dw-sat" min="0" class="daywise-input"></div>
                <div class="field" style="margin:0;"><label style="font-size:11px;">Sunday</label><input type="number" id="dw-sun" min="0" class="daywise-input"></div>
            </div>
        </div>
    </div>
    <div class="card fade-in-3">
        <div class="card-title">Reason & Remarks</div>
        <div class="field">
            <label>Reason for Change *</label>
            <select id="reason-select">
                <option value="">Select reason</option>
                <option>New residential colony opened</option>
                <option>Subscriber base increased</option>
                <option>Agency's area expanded</option>
                <option>Festival / seasonal demand</option>
                <option>Previous supply insufficient</option>
                <option>Subscriber base decreased</option>
                <option>Agency area reduced / split</option>
                <option>Competition impact</option>
                <option>Other</option>
            </select>
        </div>
        <div class="field">
            <label>Remarks for Approver (optional)</label>
            <textarea id="remarks" placeholder="Any notes for Zonal Head..."></textarea>
        </div>
    </div>
    <button class="btn btn-primary btn-icon" onclick="submitRequest()"><span>&#x1F680;</span><span>Submit for Approval</span></button>
    <div style="height:80px;"></div>
</div>
<div class="bottom-nav">
    <a class="nav-btn" href="@Url.Action("Dashboard", ctrl)"><span class="nav-icon"><img src="/icons/home_icon.svg" width="20" height="20"></span>Home</a>
    <a class="nav-btn active" href="@Url.Action("NewRequest", ctrl)"><span class="nav-icon"><img src="/icons/add_new_icon.svg" width="20" height="20"></span>New</a>
    <a class="nav-btn" href="@Url.Action("History", ctrl)"><span class="nav-icon"><img src="/icons/history_icon.svg" width="20" height="20"></span>History</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon"><img src="/icons/profile_icon.svg" width="20" height="20"></span>Profile</a>
</div>
@section Scripts {
<script>
let selectedType='I', agentData=null, supplyData=[], selectedBranchCode=null;
function toggleDayWise(){
    var section=document.getElementById('daywise-section');
    section.style.display=document.getElementById('daywise-toggle').checked?'block':'none';
    updateQtyLabel();
}
var baseCtrl='/@(ctrl)';
function selectType(t){
    selectedType=t==='increase'?'I':'D';
    document.getElementById('chip-increase').classList.toggle('active',t==='increase');
    document.getElementById('chip-decrease').classList.toggle('active',t==='decrease');
    updateQtyLabel();
    calcDiff();
}
function updateQtyLabel(){
    var daywise=document.getElementById('daywise-toggle').checked;
    var star=daywise?'':'*';
    document.getElementById('qty-label').textContent=selectedType==='I'?'Increased Quantity '+star:'Decreased Quantity '+star;
}
let searchTimer;
function searchAgent(v){
    clearTimeout(searchTimer);
    var dropdown=document.getElementById('agent-dropdown');
    if(v.length<2){dropdown.style.display='none';return;}
    document.getElementById('erp-loading').style.display='block';
    document.getElementById('erp-ok').style.display='none';
    searchTimer=setTimeout(()=>{
        fetch(baseCtrl+'/AgentSearch?q='+encodeURIComponent(v))
            .then(r=>r.json()).then(results=>{
                document.getElementById('erp-loading').style.display='none';
                if(results.length===0){
                    dropdown.innerHTML='<div style="padding:12px;font-size:12px;color:var(--muted);">No agents found</div>';
                    dropdown.style.display='block';
                    return;
                }
                let html='';
                results.forEach((a,idx)=>{
                    var dpName = a.droppointname ? '/' + a.droppointname : '';
                    html+=`<div class="agent-option" onclick="selectAgentByIndex(${idx})" style="padding:10px 14px;cursor:pointer;border-bottom:1px solid var(--border);font-size:13px;transition:background .15s;">
                        <b style="color:var(--paper);">${a.agName}</b> <span style="color:var(--blue);font-size:11px;">${a.agcd}/${a.dpcd}/${a.branchname||''}${dpName}</span>
                        <div style="font-size:11px;color:var(--muted);margin-top:2px;">PUBL: ${a.publName||''} / EDTN: ${a.edtnName||''}</div>
                    </div>`;
                });
                window._agentResults=results;
                dropdown.innerHTML=html;
                dropdown.style.display='block';
            });
    },300);
}
function selectAgentByIndex(idx){
    var a=window._agentResults[idx];
    if(!a) return;
    selectedBranchCode=a.branchCode||null;
    document.getElementById('agent-dropdown').style.display='none';
    document.getElementById('erp-loading').style.display='none';
    document.getElementById('erp-ok').style.display='block';
    agentData={agcd:a.agcd,dpcd:a.dpcd,agName:a.agName,branchCode:a.branchCode,publ:a.publ,edtn:a.edtn,publName:a.publName,edtnName:a.edtnName};
    supplyData=[{baseSupply:a.baseSupply,supplyMon:a.supplyMon,supplyTue:a.supplyTue,supplyWed:a.supplyWed,supplyThu:a.supplyThu,supplyFri:a.supplyFri,supplySat:a.supplySat,supplySun:a.supplySun,publ:a.publ,edtn:a.edtn,supplyTypeCode:a.supplyTypeCode,droppointname:a.droppointname}];
    document.getElementById('agent-name').value=a.agName||'';
    document.getElementById('agent-code').value=a.agcd||'';
    document.getElementById('agent-zone-disp').value=a.branchname||a.branchCode||'';
    document.getElementById('agent-droppoint').value=a.droppointname||'';
    document.getElementById('agent-publ-name').value=a.publName||'';
    document.getElementById('agent-edtn-name').value=a.edtnName||'';
    document.getElementById('agent-search').value=a.agName+' ('+a.agcd+')';
    document.getElementById('old-supply').value=a.baseSupply||0;
    document.getElementById('prev-old').textContent=a.baseSupply||'—';
    document.getElementById('dw-mon').value=a.supplyMon||0;
    document.getElementById('dw-tue').value=a.supplyTue||0;
    document.getElementById('dw-wed').value=a.supplyWed||0;
    document.getElementById('dw-thu').value=a.supplyThu||0;
    document.getElementById('dw-fri').value=a.supplyFri||0;
    document.getElementById('dw-sat').value=a.supplySat||0;
    document.getElementById('dw-sun').value=a.supplySun||0;
}
// Close dropdown when clicking outside
document.addEventListener('click',function(e){
    if(!e.target.closest('#agent-search')&&!e.target.closest('#agent-dropdown')){
        document.getElementById('agent-dropdown').style.display='none';
    }
});
function calcDiff(){
    let current=parseInt(document.getElementById('old-supply').value)||0;
    let qty=parseInt(document.getElementById('new-supply').value)||0;
    let total = selectedType==='I' ? current + qty : current - qty;
    var errEl=document.getElementById('supply-error');
    document.getElementById('prev-old').textContent=current;
    document.getElementById('prev-new').textContent=qty;
    if(selectedType==='D' && qty > current){
        document.getElementById('prev-diff').textContent='—';
        errEl.textContent='Decrease quantity cannot exceed current supply ('+current+')';
        errEl.style.display='block';
    } else {
        document.getElementById('prev-diff').textContent=total;
        errEl.style.display='none';
    }
}
function submitRequest(){
    if(!agentData){showToast('Please select an agent first','error');return;}
    let current=parseInt(document.getElementById('old-supply').value)||0;
    let qty=parseInt(document.getElementById('new-supply').value)||0;
    var daywise=document.getElementById('daywise-toggle').checked;
    if(!daywise && (!qty || qty<=0)){showToast('Please enter a valid quantity','error');return;}
    if(selectedType==='D' && qty > current){
        showToast('Decrease quantity cannot exceed current supply ('+current+')','error');return;
    }
    let total = qty>0 ? (selectedType==='I' ? current + qty : current - qty) : current;
    let body={
        agcd:agentData.agcd, dpcd:agentData.dpcd,
        publ:supplyData[0]?.publ, edtn:supplyData[0]?.edtn,
        supplyTypeCode:supplyData[0]?.supplyTypeCode,
        baseSupply:current,
        incDec:selectedType,
        changedSupply:total,
        unitCode:selectedBranchCode,
        reasonCode:document.getElementById('reason-select').value,
        changedSupplyDate:document.getElementById('eff-date').value||null,
        remarks:document.getElementById('remarks').value,
        dayWiseEnabled:document.getElementById('daywise-toggle').checked,
        supplyMon:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-mon').value)||null:null,
        supplyTue:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-tue').value)||null:null,
        supplyWed:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-wed').value)||null:null,
        supplyThu:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-thu').value)||null:null,
        supplyFri:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-fri').value)||null:null,
        supplySat:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-sat').value)||null:null,
        supplySun:document.getElementById('daywise-toggle').checked?parseInt(document.getElementById('dw-sun').value)||null:null
    };
    fetch(baseCtrl+'/SubmitRequest',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)})
        .then(r=>r.json()).then(d=>{
            showToast(d.message, d.success?'success':'error');
            if(d.success) setTimeout(()=>window.location.href=baseCtrl+'/Dashboard',2000);
        });
}
</script>
}
