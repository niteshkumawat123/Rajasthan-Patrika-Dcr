@model ZHDashboardViewModel
<div class="topbar">
    <div class="topbar-logo">&#x1F4F0; <span>DCR</span></div>
    <div class="topbar-user">
        <b>@Model.User?.EmpName</b>
        <span class="role-badge role-zh">Zonal Head</span>
    </div>
</div>
<div class="scroll-area">
    <div class="stats-row fade-in">
        <div class="stat-card orange"><div class="stat-num orange">@Model.AwaitingMe</div><div class="stat-label">Awaiting Me</div></div>
        <div class="stat-card green"><div class="stat-num green">@Model.Approved</div><div class="stat-label">I Approved</div></div>
        <div class="stat-card blue"><div class="stat-num blue">@Model.AtHo</div><div class="stat-label">At HO</div></div>
        <div class="stat-card red"><div class="stat-num red">@Model.Rejected</div><div class="stat-label">Rejected</div></div>
    </div>
    <div class="fade-in-2">
        <div class="section-header">
            <div class="section-title">Pending My Approval</div>
            <span class="status-pill pending">@Model.PendingRequests.Count</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var req in Model.PendingRequests)
            {
                <div class="request-card">
                    <div class="request-row">
                        <span style="font-weight:700;">@req.Agcd - @req.AgName @(string.IsNullOrEmpty(req.BranchCode) ? "" : $"({req.BranchCode})")</span>
                        <span class="status-pill pending-zh">PENDING_ZH</span>
                    </div>
                    <div class="request-row" style="font-size:12px;color:var(--muted);">
                        <span>@req.Publ / @req.Edtn</span>
                        <span>@req.CreationDate?.ToString("dd MMM yyyy")</span>
                    </div>
                    <div class="request-row" style="font-size:13px;">
                        <span>@req.BaseSupply &#x2192; @req.ChangedSupply
                            @if(req.IncDec=="I"){<span style="color:var(--green);">&#x2191;</span>}else{<span style="color:var(--accent);">&#x2193;</span>}
                        </span>
                        <span style="font-size:11px;">by @req.UserId</span>
                    </div>
                    <div class="action-row" style="margin-top:8px;">
                        <button class="btn btn-sm" style="background:var(--green);color:#fff;" onclick="zhAction(@req.ReqId,'approve')">&#x2705; Approve</button>
                        <button class="btn btn-sm" style="background:var(--accent);color:#fff;" onclick="zhAction(@req.ReqId,'reject')">&#x274C; Reject</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<div class="bottom-nav">
    <a class="nav-btn active" href="@Url.Action("Dashboard","ZH")"><span class="nav-icon">&#x1F3E0;</span>Home</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon">&#x1F464;</span>Profile</a>
</div>
@section Scripts {
<script>
let pendingAction=null, pendingReqId=null;
function zhAction(reqId, action){
    pendingReqId=reqId; pendingAction=action;
    document.getElementById('remarks-modal-title').textContent=action==='approve'?'Approve Request':'Reject Request';
    openModal('remarks-modal');
}
function confirmRemarksAction(){
    let remarks=document.getElementById('remarks-modal-input').value;
    let url=pendingAction==='approve'?'/ZH/Approve':'/ZH/Reject';
    fetch(url,{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},
        body:'reqId='+pendingReqId+'&remarks='+encodeURIComponent(remarks)})
        .then(r=>r.json()).then(d=>{
            closeModal('remarks-modal');
            showToast(d.message,d.success?'success':'error');
            if(d.success) setTimeout(()=>location.reload(),1000);
        });
}
</script>
}
