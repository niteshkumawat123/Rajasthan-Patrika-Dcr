@model ReportPageViewModel
@{
    var yesterday = Model.SelectedDate.AddDays(-1);
}
<div class="topbar">
    <a href="@Url.Action("Dashboard","HO")" class="btn btn-secondary btn-sm" style="width:auto;padding:4px 8px;text-decoration:none;">&#x2190; Back</a>
    <div style="font-size:15px;font-weight:800;">Branch Report</div>
    <div style="width:60px;"></div>
</div>
<div class="scroll-area">
    <div class="card fade-in" style="margin-bottom:16px;padding:0;overflow:hidden;">
        <div style="padding:14px 14px 8px 14px;">
            <div class="card-title" style="margin-bottom:4px;">Branch-wise Summary</div>
        </div>

        @{
            var allBranches = Model.BranchSummary.Select(b => b.BranchCode)
                .Union(Model.YesterdaySummary.Select(b => b.BranchCode))
                .Distinct().ToList();
        }

        @if (allBranches.Any())
        {
            <div style="overflow-x:auto;">
                <table style="width:100%;border-collapse:collapse;font-size:13px;">
                    <thead>
                        <tr>
                            <th rowspan="2" style="padding:10px 14px;text-align:left;font-size:12px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--border);vertical-align:bottom;min-width:160px;width:30%;">BRANCH</th>
                            <th colspan="2" style="padding:8px 10px;text-align:center;font-weight:700;color:#2e7d32;background:rgba(46,125,50,0.06);border-bottom:1px solid rgba(46,125,50,0.15);">
                                <span style="font-size:13px;">&#x2197; INCREASE</span>
                            </th>
                            <th colspan="2" style="padding:8px 10px;text-align:center;font-weight:700;color:#c62828;background:rgba(198,40,40,0.06);border-bottom:1px solid rgba(198,40,40,0.15);">
                                <span style="font-size:13px;">&#x2198; DECREASE</span>
                            </th>
                        </tr>
                        <tr>
                            <th style="padding:6px 10px;text-align:center;font-size:11px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--border);">TODAY</th>
                            <th style="padding:6px 10px;text-align:center;font-size:11px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--border);">YESTERDAY</th>
                            <th style="padding:6px 10px;text-align:center;font-size:11px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--border);">TODAY</th>
                            <th style="padding:6px 10px;text-align:center;font-size:11px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--border);">YESTERDAY</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var branchCode in allBranches)
                        {
                            var today = Model.BranchSummary.FirstOrDefault(b => b.BranchCode == branchCode);
                            var prev = Model.YesterdaySummary.FirstOrDefault(b => b.BranchCode == branchCode);
                            var branchName = today?.BranchName ?? prev?.BranchName ?? branchCode;

                            var todayInc = today?.NetIncCopies ?? 0;
                            var todayDec = today?.NetDecCopies ?? 0;
                            var prevInc = prev?.NetIncCopies ?? 0;
                            var prevDec = prev?.NetDecCopies ?? 0;

                            <tr style="border-bottom:1px solid var(--border);">
                                <td style="padding:12px;font-weight:600;color:var(--paper);white-space:nowrap;">@branchName</td>
                                <td style="padding:10px;text-align:center;">
                                    <span style="display:inline-block;background:rgba(46,125,50,0.08);color:#2e7d32;font-weight:700;padding:4px 12px;border-radius:6px;font-size:13px;">
                                        &#x2191; @todayInc
                                    </span>
                                </td>
                                <td style="padding:10px;text-align:center;">
                                    <span style="display:inline-block;background:rgba(46,125,50,0.05);color:#558b2f;font-weight:600;padding:4px 12px;border-radius:6px;font-size:13px;">
                                        &#x2191; @prevInc
                                    </span>
                                </td>
                                <td style="padding:10px;text-align:center;">
                                    <span style="display:inline-block;background:rgba(198,40,40,0.08);color:#c62828;font-weight:700;padding:4px 12px;border-radius:6px;font-size:13px;">
                                        &#x2193; @todayDec
                                    </span>
                                </td>
                                <td style="padding:10px;text-align:center;">
                                    <span style="display:inline-block;background:rgba(198,40,40,0.05);color:#d84315;font-weight:600;padding:4px 12px;border-radius:6px;font-size:13px;">
                                        &#x2193; @prevDec
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div style="text-align:center;color:var(--muted);padding:30px 20px;">
                <div style="font-size:32px;margin-bottom:8px;">&#x1F4CA;</div>
                <div>No data for selected date.</div>
            </div>
        }
    </div>
</div>
<div class="bottom-nav">
    <a class="nav-btn" href="@Url.Action("Dashboard","HO")"><span class="nav-icon"><img src="/icons/home_icon.svg" width="20" height="20"></span>Home</a>
    <a class="nav-btn" href="@Url.Action("History","HO")"><span class="nav-icon"><img src="/icons/history_icon.svg" width="20" height="20"></span>History</a>
    <a class="nav-btn active" href="@Url.Action("Reports","HO")"><span class="nav-icon"><img src="/icons/history_icon.svg" width="20" height="20"></span>Reports</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon"><img src="/icons/profile_icon.svg" width="20" height="20"></span>Profile</a>
</div>
