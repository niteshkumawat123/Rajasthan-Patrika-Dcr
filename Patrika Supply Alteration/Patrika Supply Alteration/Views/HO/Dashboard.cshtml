@model HODashboardViewModel
<div class="topbar">
    <div class="topbar-logo">&#x1F4F0; <span>DCR</span></div>
    <div class="topbar-user">
        <b>@Model.User?.EmpName</b>
        <span class="role-badge role-ho">Jaipur HO</span>
    </div>
</div>
<div class="scroll-area">
    <div class="stats-row fade-in" style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:12px;">
        <div class="stat-card orange" onclick="loadFiltered('awaiting')" style="cursor:pointer;padding:10px 6px;min-height:auto;">
            <div class="stat-num orange" style="font-size:22px;">@Model.AwaitingHo</div>
            <div class="stat-label" style="font-size:10px;">Awaiting HO</div>
        </div>
        <div class="stat-card green" onclick="loadFiltered('approved')" style="cursor:pointer;padding:10px 6px;min-height:auto;">
            <div class="stat-num green" style="font-size:22px;">@Model.HoApproved</div>
            <div class="stat-label" style="font-size:10px;">HO Approved</div>
        </div>
        <div class="stat-card blue" onclick="loadFiltered('increased')" style="cursor:pointer;padding:10px 6px;min-height:auto;">
            <div class="stat-num blue" style="font-size:22px;">@Model.TotalIncreased</div>
            <div class="stat-label" style="font-size:10px;">Increased</div>
        </div>
        <div class="stat-card red" onclick="loadFiltered('decreased')" style="cursor:pointer;padding:10px 6px;min-height:auto;">
            <div class="stat-num red" style="font-size:22px;">@Model.TotalDecreased</div>
            <div class="stat-label" style="font-size:10px;">Decreased</div>
        </div>
    </div>
    <div class="fade-in-2" id="filtered-section">
        <div class="section-header">
            <div class="section-title" id="section-title-text">Pending HO Approval</div>
            <span class="status-pill pending" id="section-count">@Model.PendingRequests.Count</span>
        </div>
        <div id="filtered-list" style="display:flex;flex-direction:column;gap:8px;">
            @foreach (var req in Model.PendingRequests)
            {
                <div class="req-item" onclick="openAuditModal(@req.ReqId)">
                    <div class="req-icon @(req.IncDec=="I"?"increase":"decrease")">@(req.IncDec=="I"?"📈":"📉")</div>
                    <div class="req-info">
                        <div class="req-agent">@req.AgName</div>
                        <div class="req-meta">
                            <span style="background:rgba(78,140,255,0.1);padding:2px 7px;border-radius:6px;font-size:11px;">@req.Publ / @req.Edtn</span>
                            @if(!string.IsNullOrEmpty(req.BranchCode)){
                            <span style="background:rgba(120,80,255,0.1);padding:2px 7px;border-radius:6px;font-size:11px;">@req.BranchCode</span>
                            }
                            <span style="font-size:11px;color:var(--muted);">@req.CreationDate?.ToString("dd MMM yyyy")</span>
                        </div>
                        <div class="req-by">@req.Agcd &middot; @req.BaseSupply → @req.ChangedSupply @(req.IncDec=="I"?"↑":"↓") &middot; By @req.CreationBy</div>
                        @if(req.ZhApprovedBy!=null){
                        <div style="font-size:11px;color:var(--muted);">ZH: @req.ZhApprovedBy @(string.IsNullOrEmpty(req.ZhRemarks) ? "" : $"· {req.ZhRemarks}")</div>
                        }
                    </div>
                    <div style="flex-shrink:0;display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
                        <span class="status-pill pending-ho">PENDING_HO</span>
                        <div style="display:flex;flex-direction:row;gap:6px;">
                            <button class="quick-approve-btn" onclick="event.stopPropagation();hoApprove(@req.ReqId,'@req.Agcd','@req.Dpcd','@req.Publ','@req.Edtn','@req.SupplyTypeCode',@(req.ChangedSupply??0),'@req.ChangedSupplyDate?.ToString("yyyy-MM-dd")')" title="Approve & Push ERP">✅</button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
<div class="bottom-nav">
    <a class="nav-btn active" href="@Url.Action("Dashboard","HO")"><span class="nav-icon">&#x1F3E0;</span>Home</a>
    <a class="nav-btn" href="@Url.Action("History","HO")"><span class="nav-icon">&#x1F4CB;</span>History</a>
    <a class="nav-btn" href="@Url.Action("Reports","HO")"><span class="nav-icon">&#x1F4CA;</span>Reports</a>
    <a class="nav-btn" href="@Url.Action("Index","Profile")"><span class="nav-icon">&#x1F464;</span>Profile</a>
</div>
@section Scripts {
<script>
let hoReqData={};
let activeFilter='awaiting';

function loadFiltered(status){
    activeFilter=status;
    let titles={'awaiting':'Pending HO Approval','approved':'HO Approved','increased':'Total Increased','decreased':'Total Decreased'};
    document.getElementById('section-title-text').textContent=titles[status]||'Requests';
    document.getElementById('filtered-list').innerHTML='<div style="text-align:center;padding:20px;color:#999;">Loading...</div>';

    document.querySelectorAll('.stat-card').forEach(c=>c.style.outline='none');
    let idx={'awaiting':0,'approved':1,'increased':2,'decreased':3};
    let cards=document.querySelectorAll('.stat-card');
    if(cards[idx[status]]) cards[idx[status]].style.outline='2px solid #4e8cff';

    fetch('/HO/FilteredRequests?status='+status).then(r=>r.json()).then(data=>{
        document.getElementById('section-count').textContent=data.length;
        if(!data||data.length===0){
            document.getElementById('filtered-list').innerHTML='<div style="text-align:center;padding:20px;color:#999;">No records found</div>';
            return;
        }
        let html='';
        data.forEach(req=>{
            let isInc=req.incDec==='I';
            let statusLabel=(req.status||'').replace(/_/g,' ');
            let statusCls=(req.status||'').toLowerCase().replace(/_/g,'-');
            let dateStr=req.creationDate?new Date(req.creationDate).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'2-digit'}):'';
            let showActions=(status==='awaiting');
            html+=`<div class="req-item" onclick="openAuditModal(${req.reqId})" style="cursor:pointer;">
                <div class="req-icon ${isInc?'increase':'decrease'}">${isInc?'📈':'📉'}</div>
                <div class="req-info">
                    <div class="req-agent">${req.agName||''}</div>
                    <div class="req-meta">
                        <span style="background:rgba(78,140,255,0.1);padding:2px 7px;border-radius:6px;font-size:11px;">${req.publ||''} / ${req.edtn||''}</span>
                        <span style="font-size:11px;color:var(--muted);">${dateStr}</span>
                    </div>
                    <div class="req-by">${req.agcd||''} &middot; ${req.baseSupply||0} → ${req.changedSupply||0} ${isInc?'↑':'↓'} &middot; By ${req.creationBy||''}</div>
                </div>
                <div style="flex-shrink:0;display:flex;flex-direction:column;gap:6px;align-items:flex-end;">
                    <span class="status-pill ${statusCls}">${statusLabel}</span>
                    ${showActions?`<div style="display:flex;flex-direction:row;gap:6px;">
                        <button class="quick-approve-btn" onclick="event.stopPropagation();hoApprove(${req.reqId},'${req.agcd}','${req.dpcd}','${req.publ}','${req.edtn}','${req.supplyTypeCode||''}',${req.changedSupply||0},'${req.changedSupplyDate?req.changedSupplyDate.substring(0,10):''}')" title="Approve & Push ERP">✅</button>
                    </div>`:''}
                </div>
            </div>`;
        });
        document.getElementById('filtered-list').innerHTML=html;
    });
}

function hoApprove(reqId,agcd,dpcd,publ,edtn,stc,cs,csd){
    hoReqData={reqId,agcd,dpcd,publ,edtn,supplyTypeCode:stc,changedSupply:cs,changedSupplyDate:csd};
    document.getElementById('remarks-modal-title').textContent='Approve & Push to ERP';
    document.getElementById('remarks-modal-label').textContent='Remarks (optional)';
    document.getElementById('remarks-modal-input').value='';
    var btn=document.getElementById('remarks-confirm-btn');
    btn.textContent='Approve & Push ERP';
    btn.className='btn btn-primary';
    openModal('remarks-modal');
}

function confirmRemarksAction(){
    let remarks=document.getElementById('remarks-modal-input').value;
    let body='reqId='+hoReqData.reqId+'&remarks='+encodeURIComponent(remarks)
        +'&agcd='+hoReqData.agcd+'&dpcd='+hoReqData.dpcd
        +'&publ='+hoReqData.publ+'&edtn='+hoReqData.edtn
        +'&supplyTypeCode='+hoReqData.supplyTypeCode
        +'&changedSupply='+hoReqData.changedSupply
        +'&changedSupplyDate='+hoReqData.changedSupplyDate;
    fetch('/HO/Approve',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:body})
        .then(r=>r.json()).then(d=>{
            closeModal('remarks-modal');
            showToast(d.message,d.success?'success':'error');
            if(d.success) setTimeout(()=>location.reload(),1000);
        });
}

function openAuditModal(reqId){
    fetch('/Home/AuditTrail?reqId='+reqId).then(r=>r.json()).then(data=>{
        if(!data||data.length===0){showToast('No details found','error');return;}
        let r=data[0];
        let diff=(r.changedSupply||0)-(r.baseSupply||0);
        let diffStr=(diff>0?'+':'')+diff;
        let diffColor=diff>0?'#00b894':'var(--accent)';
        let statusLabel=(r.status||'').replace(/_/g,' ').toUpperCase();
        let statusCls=(r.status||'').toLowerCase().replace(/_/g,'-');
        let dateStr=r.creationDate?new Date(r.creationDate).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'2-digit'}):'';
        let timeStr=r.creationDate?new Date(r.creationDate).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}):'';
        let effDate=r.changedSupplyDate?new Date(r.changedSupplyDate).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'2-digit'}):'-';

        let html=`
        <div style="display:flex;gap:8px;margin-bottom:16px;align-items:center;flex-wrap:wrap;">
          <span class="status-pill ${statusCls}" style="font-size:11px;padding:5px 12px;">${statusLabel}</span>
          <span style="font-size:12px;color:var(--muted);">${dateStr} · ${timeStr}</span>
        </div>
        <div style="background:#e8f4fd;border-radius:12px;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
          <div style="text-align:left"><div style="font-size:28px;font-weight:700;color:#222;">${r.baseSupply||0}</div><div style="font-size:11px;color:#666;text-transform:uppercase;font-weight:600;">Current</div></div>
          <div style="font-size:20px;color:#888;">📝</div>
          <div style="text-align:center"><div style="font-size:28px;font-weight:700;color:${diffColor};">${r.changedSupply||0}</div><div style="font-size:11px;color:#666;text-transform:uppercase;font-weight:600;">New</div></div>
          <div style="text-align:right"><div style="font-size:20px;font-weight:700;color:${diffColor};">${diffStr}</div><div style="font-size:11px;color:#666;text-transform:uppercase;font-weight:600;">Diff</div></div>
        </div>
        <div style="font-size:13px;line-height:2.2;margin-bottom:14px;">
          <span style="color:#888;">Agency:</span> <b>${r.agName||''}</b> (${r.agcd||''})<br>
          <span style="color:#888;">Zone:</span> <b>${r.zoneCode||'-'}</b><br>
          <span style="color:#888;">Branch:</span> <b>${r.branchName||''}</b><br>
          <span style="color:#888;">Effective Date:</span> <b>${effDate}</b><br>
          <span style="color:#888;">By:</span> <b>${r.submittedbyname||''}</b>
        </div>
        <div style="font-size:11px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Reason & Remarks</div>
        <div style="background:rgba(231,111,81,0.07);border-left:3px solid rgba(231,111,81,0.5);border-radius:8px;padding:12px 16px;margin-bottom:10px;">
          <div style="font-size:11px;font-weight:700;color:var(--accent);text-transform:uppercase;margin-bottom:4px;">Reason</div>
          <div style="font-size:13px;color:#333;">${r.reasonCode||'-'}</div>
        </div>
        <div style="background:rgba(231,111,81,0.07);border-left:3px solid rgba(231,111,81,0.5);border-radius:8px;padding:12px 16px;margin-bottom:10px;">
          <div style="font-size:11px;font-weight:700;color:var(--accent);text-transform:uppercase;margin-bottom:4px;">Remarks</div>
          <div style="font-size:13px;color:#333;">${r.remarks||'—'}</div>
        </div>`;

        let zhRem='',hoRem='';
        data.forEach(a=>{
            if(a.approvalLevel&&a.approvalLevel.indexOf('ZH')>=0&&a.approverRemarks) zhRem=a.approverRemarks;
            if(a.approvalLevel&&a.approvalLevel.indexOf('HO')>=0&&a.approverRemarks) hoRem=a.approverRemarks;
        });
        if(zhRem) html+=`<div style="font-size:12px;color:var(--muted);line-height:1.6;margin-top:8px;"><b style="color:var(--green);">ZH Remarks:</b> ${zhRem}</div>`;
        if(hoRem) html+=`<div style="font-size:12px;color:var(--muted);line-height:1.6;margin-top:5px;"><b style="color:var(--accent);">HO Remarks:</b> ${hoRem}</div>`;

        document.getElementById('modal-title').textContent='Request #REQ'+String(r.reqId).padStart(3,'0');
        document.getElementById('modal-body').innerHTML=html;
        openModal('detail-modal');
    });
}
</script>
}
