@model ChangePasswordViewModel

@{
    Layout = "_LoginLayout";
}
<div class="login-box">
    <div class="login-header fade-in">
        <div style="font-size:52px;margin-bottom:12px;">&#x1F510;</div>
        <h1>Patrika Supply Alteration</h1>
    </div>
    <div class="fade-in-2">
        <div class="card-title" style="margin-bottom:14px;">Change Password</div>
        <p style="font-size:14px;color:#888;margin-bottom:16px;">This is your first login. Please set a new password to continue.</p>
        <form method="post" asp-action="ChangePassword">
            @Html.AntiForgeryToken()
            <input type="hidden" name="EmployeeCode" value="@Model.EmployeeCode" />
            <div class="login-field">
                <label>New Password</label>
                <input type="password" name="NewPassword" placeholder="Enter new password" autocomplete="new-password">
            </div>
            <div class="login-field">
                <label>Confirm Password</label>
                <input type="password" name="ConfirmPassword" placeholder="Confirm new password" autocomplete="new-password">
            </div>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error" style="display:block;">@Model.ErrorMessage</div>
            }
            <button type="submit" class="btn btn-primary btn-icon" style="margin-top:4px;"><span>Change Password</span><span>&#x2192;</span></button>
        </form>
        <div style="margin-top:12px;text-align:center;">
            <a asp-action="Login" style="color:var(--blue);text-decoration:none;font-size:14px;">&#x2190; Back to Login</a>
        </div>
    </div>
</div>
