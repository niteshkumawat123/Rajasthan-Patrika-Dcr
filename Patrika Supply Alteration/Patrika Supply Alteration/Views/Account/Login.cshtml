@model LoginViewModel
@{
    Layout = "_LoginLayout";
}
<div class="login-box">
    <div class="login-header fade-in">
        <div style="font-size:52px;margin-bottom:12px;">&#x1F4F0;</div>
        <h1>DCR Supply App</h1>
        <p>Newspaper Circulation Management · Jaipur HO</p>
    </div>
    <div class="fade-in-2">
        <div class="card-title" style="margin-bottom:14px;">Login</div>
        <div style="margin-bottom:12px;">
            <span class="role-badge role-se" style="font-size:11px;padding:5px 14px;">@Model.RoleName</span>
        </div>
        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <input type="hidden" name="RoleCode" value="@Model.RoleCode" />
            <input type="hidden" name="RoleName" value="@Model.RoleName" />
            <div class="login-field">
                <label>Employee ID (Username)</label>
                <input type="text" name="EmployeeId" placeholder="Enter Employee ID" autocomplete="off" value="@Model.EmployeeId">
            </div>
            <div class="login-field">
                <label>Password</label>
                <input type="password" name="Password" placeholder="Enter password">
            </div>
            <div class="forgot-link"><a asp-action="ForgotPassword" style="color:var(--blue);text-decoration:none;">Forgot Password?</a></div>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error" style="display:block;">@Model.ErrorMessage</div>
            }
            <button type="submit" class="btn btn-primary btn-icon" style="margin-top:4px;"><span>Login</span><span>&#x2192;</span></button>
        </form>
        <a asp-action="RoleSelect" class="btn btn-secondary" style="margin-top:10px;display:block;text-align:center;text-decoration:none;">&#x2190; Back to Roles</a>
    </div>
</div>
