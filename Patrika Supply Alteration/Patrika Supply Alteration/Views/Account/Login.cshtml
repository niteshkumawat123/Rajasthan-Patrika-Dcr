@model LoginViewModel

@{
    Layout = "_LoginLayout";
}
<div class="login-box">
    <div class="login-header fade-in">
        <div style="font-size:52px;margin-bottom:12px;">&#x1F4F0;</div>
        <h1>Patrika Supply Alteration</h1>
    </div>
    <div class="fade-in-2">
        <div class="card-title" style="margin-bottom:14px;">Login</div>
        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <div class="login-field">
                <label>Employee ID (Username)</label>
                <input type="text" name="EmployeeId" placeholder="Enter Employee ID" autocomplete="off" value="@Model.EmployeeId">
            </div>
            <div class="login-field">
                <label>Password</label>
                <input type="password" name="Password" placeholder="Enter password">
            </div>
            <div class="forgot-link"><a asp-action="ForgotPassword" style="color:var(--blue);text-decoration:none;">Forgot Password?</a></div>
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="login-error" style="display:block;">@Model.ErrorMessage</div>
            }
            <button type="submit" class="btn btn-primary btn-icon" style="margin-top:4px;"><span>Login</span><span>&#x2192;</span></button>
        </form>
    </div>
</div>
