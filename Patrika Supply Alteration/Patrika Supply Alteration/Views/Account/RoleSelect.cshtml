@model List<RoleViewModel>
@{
    Layout = "_LoginLayout";
}
<div class="login-box">
    <div class="login-header fade-in">
        <div style="font-size:52px;margin-bottom:12px;">&#x1F4F0;</div>
        <h1>DCR Supply App</h1>
        <p>Newspaper Circulation Management · Jaipur HO</p>
    </div>
    <div class="fade-in-2">
        <div class="card-title" style="margin-bottom:10px;">Select Your Role</div>
        <div class="role-select-grid">
            @if (Model != null)
            {
                @foreach (var role in Model)
                {
                    <form method="post" asp-action="RoleSelect" style="display:contents;">
                        <input type="hidden" name="code" value="@role.Code" />
                        <input type="hidden" name="name" value="@role.Name" />
                        <div class="role-card" onclick="this.closest('form').submit();">
                            <div class="role-emoji">
                                @if (role.Name?.Contains("SE") == true || role.Name?.ToLower().Contains("sales") == true || role.Name?.ToLower().Contains("executive") == true)
                                {<span style="font-size:32px;">&#x1F4CB;</span>}
                                else if (role.Name?.Contains("ZH") == true || role.Name?.ToLower().Contains("zonal") == true)
                                {<span style="font-size:32px;">&#x1F3E2;</span>}
                                else
                                {<span style="font-size:32px;">&#x1F3E6;</span>}
                            </div>
                            <div class="role-info">
                                <b>@role.Name</b>
                                <span>
                                    @if (role.Name?.Contains("SE") == true || role.Name?.ToLower().Contains("sales") == true)
                                    {<text>Submit supply change requests</text>}
                                    else if (role.Name?.Contains("ZH") == true || role.Name?.ToLower().Contains("zonal") == true)
                                    {<text>First-level approval authority</text>}
                                    else
                                    {<text>Final approval &amp; ERP push</text>}
                                </span>
                            </div>
                        </div>
                    </form>
                }
            }
        </div>
    </div>
</div>
